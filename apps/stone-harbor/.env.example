# Stone Harbor — environment variable template.
#
# Copy to .env.local and fill in. Vercel mirrors these per environment
# (Production / Preview / Development). Never commit real secrets.

# --- Supabase (Stone Harbor application database) -------------------
# These power both the browser Supabase client and server-side service
# helpers. NEXT_PUBLIC_* values reach the browser by design.
NEXT_PUBLIC_SUPABASE_URL=https://your-stone-harbor-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only. Never set in Preview if the preview
# environment is accessible to anyone besides Rafael.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers ---------------------------------------------------
OPENAI_API_KEY=
RESEND_API_KEY=

# --- Eidos behavioral engine (SH-36) --------------------------------
# Stone Harbor pushes behavioral events (journal.created, vent.created)
# to the standalone Eidos engine via /api/events/emit -> lib/eidos.ts.
# Both vars are server-only — the browser never sees the consumer
# token. Token rotation tracked under EID-38.
#
# EIDOS_INGEST_URL is optional; the helper defaults to the production
# endpoint when unset. Override for local dev or staging.
EIDOS_CONSUMER_TOKEN=
# EIDOS_INGEST_URL=https://eidos.stoneharbor.app/api/v1/events

# --- Admin (legacy /admin gate; will be retired post-launch) --------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Test members (used by Playwright e2e) --------------------------
TEST_MEMBER_EMAIL=
TEST_MEMBER_PASSWORD=

# --- Image curation -------------------------------------------------
UNSPLASH_ACCESS_KEY=
