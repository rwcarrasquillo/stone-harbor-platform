# Eidos Engine — environment contract.
# Copy to .env.local for local dev. Production values live in Vercel.
# All vars are un-prefixed (server-only); none are exposed to the browser.

# Standalone Eidos Supabase project ("eidos-engine", id xfsqytpitltfeacvmvqm).
# NOT Stone Harbor's prod DB (fbqcmtcvgijlemfpncay).
SUPABASE_URL=https://xfsqytpitltfeacvmvqm.supabase.co
SUPABASE_ANON_KEY=
# Service-role key — production scope only, never commit, never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret authenticating Vercel cron invocations of construct-compute
# jobs (EID-20+). 32+ random chars. Set in production AND development scopes.
# Vercel cron auto-signs requests with the literal env-var name CRON_SECRET,
# so set both to the same value to enable Vercel's built-in cron auth.
EIDOS_CRON_SECRET=
CRON_SECRET=

# Shared secret guarding /admin/* (admin spot-check view, EID-21). Used as
# the password in HTTP Basic Auth — the username is ignored. Browser
# prompts on first /admin visit and caches for the session. 32+ random
# chars; rotate independently of consumer + cron secrets.
EIDOS_ADMIN_TOKEN=
