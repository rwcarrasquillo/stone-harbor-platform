# Eidos Admin — environment contract.
# Copy to .env.local for local dev. Production values live in Vercel.
# All vars are un-prefixed (server-only); none are exposed to the browser.

# URL of the Eidos engine deployment that this admin app reads from.
# Production: https://eidos.stoneharbor.app
# Local dev:  http://localhost:3000  (or wherever eidos-engine is running)
EIDOS_API_URL=https://eidos.stoneharbor.app

# Bearer token the admin app uses when calling the engine's
# /api/v1/members and /api/v1/members/[consumer_id]/[user_id]
# endpoints. Must match the EIDOS_ADMIN_API_TOKEN env var on the
# engine deployment. 32+ random chars. Rotate independently of
# consumer + cron secrets.
EIDOS_ADMIN_API_TOKEN=

# Shared password guarding the admin app's login page. Used as the
# password in the cookie-session login flow — the username is ignored.
# Distinct from EIDOS_ADMIN_API_TOKEN so the credential held by the
# browser (in the session cookie) is different from the credential
# held by the server (in the engine API auth header). 32+ random chars.
EIDOS_ADMIN_PASSWORD=
