# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
.turbo/

# next.js
# Match both the directory (default) AND a symlink named .next that
# may exist locally when bridging the build cache to native disk
# inside a Parallels VM. The trailing-slash form alone misses symlinks.
.next
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Test artifacts
.test-results/
# Playwright screenshot artifacts (local dev / preview captures only)
**/.settle-in-shots/

# Claude Code local config (Cowork / Claude Code workspace settings)
.claude/

# Sentry Config File
.env.sentry-build-plugin
